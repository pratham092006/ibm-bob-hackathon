# Google Gemini API Configuration
# Get your API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Anthropic Claude API Configuration
# Get your API key from: https://console.anthropic.com/
CLAUDE_API_KEY=your_claude_api_key_here

# OpenRouter API Configuration
# Get your API key from: https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=anthropic/claude-3.5-haiku

# NVIDIA API Configuration
# Get your API key from: https://build.nvidia.com/
NVIDIA_API_KEY=your_nvidia_api_key_here
# Vision-Language Model for computer control
# meta/llama-3.2-90b-vision-instruct - 90B parameter model for vision-instruction following
NVIDIA_MODEL=meta/llama-3.2-90b-vision-instruct

# Ollama Local Model Configuration
# Get models from: https://ollama.com/library
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2-vision:11b

# LLM Provider Selection
# Options: "claude", "gemini", "openrouter", "nvidia", or "ollama"
LLM_PROVIDER=ollama

# Claude Model Selection
# Options: "claude-3-5-sonnet-20241022", "claude-3-5-haiku-20241022", "claude-3-opus-20240229"
CLAUDE_MODEL=claude-3-5-sonnet-20241022